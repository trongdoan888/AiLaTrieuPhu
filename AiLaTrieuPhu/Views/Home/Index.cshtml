@{
    Layout = null; 
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Menu - Ai Là Triệu Phú</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
            /* Nền tối sâu thẳm giống trường quay */
            body, html {
                margin: 0;
                padding: 0;
                height: 100%;
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                background: radial-gradient(circle, #102a4d 0%, #020b1a 100%);
                display: flex;
                justify-content: center;
                align-items: center;
            }

            .menu-container {
                text-align: center;
                width: 100%;
                max-width: 500px;
                padding: 20px;
            }

            /* Logo game */
            .logo-wrapper {
                margin-bottom: 40px;
                animation: glow 2s infinite alternate;
            }

            .main-logo {
                width: 100px;
                height: 100px;
                border: 5px solid #ffcc00;
                border-radius: 50%;
                margin: 0 auto 15px;
                color: #ffcc00;
                font-size: 60px;
                font-weight: bold;
                display: flex;
                justify-content: center;
                align-items: center;
                box-shadow: 0 0 20px rgba(255, 204, 0, 0.6);
            }

            h1 {
                color: #ffffff;
                text-shadow: 0 0 10px #00d4ff;
                letter-spacing: 3px;
                margin: 0;
            }

            /* Các nút Menu */
            .menu-buttons {
                display: flex;
                flex-direction: column;
                gap: 15px;
            }

            .btn-menu {
                display: block;
                background: linear-gradient(180deg, #1a4a8a 0%, #051933 100%);
                border: 2px solid #00d4ff;
                color: #ffffff;
                padding: 15px 20px;
                text-decoration: none;
                font-size: 18px;
                font-weight: bold;
                border-radius: 30px;
                text-transform: uppercase;
                transition: all 0.3s ease;
                position: relative;
                overflow: hidden;
            }

            .btn-menu i {
                margin-right: 10px;
                color: #ffcc00;
            }

            .btn-menu:hover {
                background: #ffcc00;
                color: #051933;
                border-color: #ffcc00;
                box-shadow: 0 0 20px rgba(255, 204, 0, 0.8);
                transform: scale(1.05);
            }

            .btn-menu:hover i {
                color: #051933;
            }

            .btn-logout {
                border-color: #ff4d4d;
                margin-top: 20px;
            }

            .btn-logout i {
                color: #ff4d4d;
            }

            .btn-logout:hover {
                background: #ff4d4d;
                border-color: #ff4d4d;
                box-shadow: 0 0 20px rgba(255, 77, 77, 0.8);
            }

            @@keyframes glow {
                from { text-shadow: 0 0 10px #00d4ff, 0 0 20px #00d4ff; }
                to { text-shadow: 0 0 20px #00d4ff, 0 0 30px #00d4ff; }
            }
    </style>
</head>
<body>
    <div class="menu-container">
        <div class="logo-wrapper">
            <div class="main-logo">?</div>
            <h1>AI LÀ TRIỆU PHÚ</h1>
        </div>

        <div class="menu-buttons">
            <a href="/Game/Index" class="btn-menu"><i class="fas fa-play"></i> Chơi Game</a>
            <a href="/Home/About" class="btn-menu"><i class="fas fa-info-circle"></i> Giới Thiệu</a>
            <a href="/Ranking/Index" class="btn-menu"><i class="fas fa-trophy"></i> Bảng Xếp Hạng</a>
            
            <a href="/History/Index?userId=@ViewBag.UserId" class="btn-menu"><i class="fas fa-history"></i> Lịch Sử Chơi</a>
            
            <a href="/Account/Logout" class="btn-menu btn-logout" onclick="return confirm('Bạn có chắc chắn muốn rời khỏi trường quay không?');"><i class="fas fa-sign-out-alt"></i> Đăng Xuất</a>
        </div>
    </div>
</body>
</html>