@{ Layout = null; }
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Quên mật khẩu - Ai Là Triệu Phú</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&display=swap');
        body { background: #030712; color: white; font-family: 'Rajdhani', sans-serif; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
        .glass-box { background: rgba(6, 15, 30, 0.9); padding: 40px; border-radius: 20px; border: 1px solid #00d4ff; width: 100%; max-width: 420px; text-align: center; box-shadow: 0 0 30px rgba(0, 212, 255, 0.2); }
        .input-group { text-align: left; margin-bottom: 15px; }
        label { color: #00d4ff; font-size: 13px; font-weight: bold; text-transform: uppercase; margin-bottom: 5px; display: block; }
        input { width: 100%; padding: 12px; background: #020813; border: 1px solid #1a4a8a; color: white; border-radius: 8px; box-sizing: border-box; transition: 0.3s; }
        input:focus { border-color: #ffcc00; outline: none; box-shadow: 0 0 10px rgba(255, 204, 0, 0.3); }
        .btn-reset { background: #ffcc00; color: black; border: none; padding: 14px; width: 100%; border-radius: 8px; font-weight: bold; cursor: pointer; transition: 0.3s; text-transform: uppercase; margin-top: 10px; font-size: 16px; }
        .btn-reset:hover { background: white; box-shadow: 0 0 20px #ffcc00; transform: translateY(-2px); }
        .msg-error { color: #ff4d4d; margin-bottom: 15px; background: rgba(255, 77, 77, 0.1); padding: 10px; border-radius: 5px; border: 1px solid #ff4d4d; }
        .msg-success { color: #00ffcc; margin-bottom: 15px; background: rgba(0, 255, 204, 0.1); padding: 10px; border-radius: 5px; border: 1px solid #00ffcc; }
    </style>
</head>
<body>
    <div class="glass-box">
        <h2 style="color: #00d4ff; letter-spacing: 2px;"><i class="fas fa-shield-alt"></i> KHÔI PHỤC TÀI KHOẢN</h2>
        <p style="color: #a1b0c9; font-size: 14px; margin-bottom: 25px;">Hệ thống sẽ kiểm tra thông tin để cấp lại mật khẩu.</p>

        @if (ViewBag.Error != null) { <div class="msg-error"><i class="fas fa-exclamation-triangle"></i> @ViewBag.Error</div> }
        @if (ViewBag.Success != null) { <div class="msg-success"><i class="fas fa-check-circle"></i> @ViewBag.Success</div> }

        <form asp-action="SendOTP" asp-controller="Account" method="post">
            <div class="input-group">
                <label>Tên tài khoản</label>
                <input type="text" name="username" placeholder="Nhập username..." required />
            </div>

            <div class="input-group">
                <label>Email đăng ký</label>
                <input type="email" name="email" placeholder="example@gmail.com..." required />
            </div>

            <button type="submit" class="btn-reset">Xác nhận đặt lại</button>
        </form>

        <div style="margin-top: 25px;">
            <a href="/Account/Login" style="color: #00d4ff; text-decoration: none; font-size: 14px;">
                <i class="fas fa-arrow-left"></i> Quay lại Đăng nhập
            </a>
        </div>
    </div>
</body>
</html>