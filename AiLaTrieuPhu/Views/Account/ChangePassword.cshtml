@{ Layout = null; }
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Đổi Mật Khẩu - Ai Là Triệu Phú</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&display=swap');
        body { 
            margin: 0; padding: 0; height: 100vh; display: flex; justify-content: center; align-items: center;
            background: radial-gradient(circle at center, #0a1f44 0%, #020813 100%);
            font-family: 'Rajdhani', sans-serif; color: white;
        }
        .change-box {
            background: rgba(6, 15, 30, 0.8); padding: 40px; border-radius: 20px;
            border: 2px solid #ffcc00; box-shadow: 0 0 30px rgba(255, 204, 0, 0.2);
            text-align: center; width: 100%; max-width: 380px; backdrop-filter: blur(10px);
        }
        .change-box h2 { color: #ffcc00; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 25px; }
        .input-group { margin-bottom: 15px; }
        .input-group input {
            width: 100%; padding: 12px 20px; border-radius: 30px; border: 1px solid #ffcc00;
            background: rgba(0,0,0,0.3); color: white; outline: none; font-size: 16px; box-sizing: border-box;
        }
        .btn-submit {
            width: 100%; padding: 12px; border-radius: 30px; border: none;
            background: linear-gradient(180deg, #ffcc00, #b38f00); color: black;
            font-size: 18px; font-weight: bold; cursor: pointer; transition: 0.3s; text-transform: uppercase;
        }
        .btn-submit:hover { box-shadow: 0 0 20px #ffcc00; transform: scale(1.03); }
        .error-msg { color: #ff4d4d; background: rgba(255,77,77,0.1); padding: 10px; border-radius: 8px; border: 1px solid #ff4d4d; margin-bottom: 15px; font-size: 14px; }
        
        /* Modal Success */
        .modal-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.9); display: flex; justify-content: center; align-items: center; z-index: 100; }
        .modal-content { background: #051024; border: 2px solid #00ffcc; padding: 30px; border-radius: 20px; text-align: center; box-shadow: 0 0 30px #00ffcc; }
    </style>
</head>
<body>
    <div class="change-box">
        <div style="font-size: 40px; color: #ffcc00; margin-bottom: 10px;"><i class="fas fa-user-shield"></i></div>
        <h2>Đổi Mật Khẩu</h2>

        @if (ViewBag.Error != null)
        {
            <div class="error-msg">@ViewBag.Error</div>
        }

        <form method="post" action="/Account/ChangePassword">
            <div class="input-group">
                <input type="text" name="username" placeholder="Tên tài khoản" required />
            </div>
            <div class="input-group">
                <input type="password" name="oldPassword" placeholder="Mật khẩu cũ" required />
            </div>
            <div class="input-group">
                <input type="password" name="newPassword" placeholder="Mật khẩu mới (ít nhất 6 ký tự)" required />
            </div>
            <button type="submit" class="btn-submit">XÁC NHẬN ĐỔI</button>
        </form>

        <a href="/Account/Login" style="color: #00d4ff; text-decoration: none; display: block; margin-top: 20px; font-size: 14px;">Quay lại Đăng nhập</a>
    </div>

    @if (ViewBag.Success != null)
    {
        <div class="modal-overlay">
            <div class="modal-content">
                <h3 style="color: #00ffcc; font-size: 24px;"><i class="fas fa-check-circle"></i> THÀNH CÔNG!</h3>
                <p style="margin-bottom: 20px;">@ViewBag.Success</p>
                <a href="/Account/Login" style="background: #00ffcc; color: black; padding: 10px 30px; border-radius: 20px; text-decoration: none; font-weight: bold;">ĐĂNG NHẬP NGAY</a>
            </div>
        </div>
    }
</body>
</html>