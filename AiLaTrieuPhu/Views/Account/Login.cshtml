@model AiLaTrieuPhu.Models.User
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - Ai Là Triệu Phú</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        body { 
            margin: 0; padding: 0; height: 100vh; display: flex; justify-content: center; align-items: center;
            background: radial-gradient(circle at center, #0a1f44 0%, #020813 100%);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; color: white;
        }
        .login-box {
            background: rgba(0, 0, 0, 0.6); padding: 40px; border-radius: 20px;
            border: 2px solid #00d4ff; box-shadow: 0 0 20px rgba(0, 212, 255, 0.5);
            text-align: center; width: 100%; max-width: 350px;
        }
        .login-box h2 { color: #ffcc00; margin-top: 0; margin-bottom: 25px; font-size: 28px; text-transform: uppercase; }
        .input-group { margin-bottom: 20px; text-align: left; }
        .input-group input {
            width: 100%; padding: 12px; border-radius: 30px; border: 1px solid #00d4ff;
            background: transparent; color: white; outline: none; font-size: 16px; box-sizing: border-box;
        }
        .btn-submit {
            width: 100%; padding: 12px; border-radius: 30px; border: none;
            background: linear-gradient(180deg, #ffcc00, #b38f00); color: black;
            font-size: 18px; font-weight: bold; cursor: pointer; transition: 0.3s;
        }
        .btn-submit:hover { box-shadow: 0 0 15px #ffcc00; transform: scale(1.05); }
        .register-link { display: block; margin-top: 20px; color: #00d4ff; text-decoration: none; }
        .register-link:hover { text-decoration: underline; color: white; }
        .error-msg { color: #ff4d4d; margin-bottom: 15px; font-weight: bold; }
    </style>
</head>
<body>
    <div class="login-box">
        <div style="width: 60px; height: 60px; border: 3px solid #ffcc00; border-radius: 50%; margin: 0 auto 15px; display: flex; justify-content: center; align-items: center; font-size: 30px; color: #ffcc00; box-shadow: 0 0 15px #ffcc00;">?</div>
        <h2>Đăng Nhập</h2>
        @if (ViewBag.Error != null)
        {
            <div class="error-msg">@ViewBag.Error</div>
        }
        <form method="post" action="/Account/Login">
            <div class="input-group">
                <input type="text" name="Username" placeholder="Tên tài khoản" required autocomplete="off" />
            </div>
            <div class="input-group">
                <input type="password" name="Password" placeholder="Mật khẩu" required />
            </div>
            <button type="submit" class="btn-submit">VÀO TRƯỜNG QUAY</button>
        </form>
        <a href="/Account/Register" class="register-link">Chưa có vé? Đăng ký ngay</a>
    </div>
</body>
</html>