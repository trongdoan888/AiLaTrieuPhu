@model AiLaTrieuPhu.Models.User
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - Ai Là Triệu Phú</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&display=swap');

        body { 
            margin: 0; padding: 0; height: 100vh; display: flex; justify-content: center; align-items: center;
            background: radial-gradient(circle at center, #0a1f44 0%, #020813 100%);
            font-family: 'Rajdhani', 'Segoe UI', sans-serif; color: white;
        }
        .login-box {
            background: rgba(6, 15, 30, 0.8); padding: 40px; border-radius: 20px;
            border: 2px solid #00d4ff; box-shadow: 0 0 30px rgba(0, 212, 255, 0.3);
            text-align: center; width: 100%; max-width: 350px; backdrop-filter: blur(10px);
        }
        .login-box h2 { color: #ffcc00; margin-top: 0; margin-bottom: 25px; font-size: 28px; text-transform: uppercase; letter-spacing: 2px; }
        .input-group { margin-bottom: 15px; text-align: left; }
        .input-group input {
            width: 100%; padding: 12px 20px; border-radius: 30px; border: 1px solid #00d4ff;
            background: rgba(0,0,0,0.3); color: white; outline: none; font-size: 16px; box-sizing: border-box;
            transition: 0.3s;
        }
        .input-group input:focus { box-shadow: 0 0 10px #00d4ff; background: rgba(0,0,0,0.5); }
        
        .btn-submit {
            width: 100%; padding: 12px; border-radius: 30px; border: none;
            background: linear-gradient(180deg, #ffcc00, #b38f00); color: black;
            font-size: 18px; font-weight: bold; cursor: pointer; transition: 0.3s;
            text-transform: uppercase; letter-spacing: 1px; margin-top: 10px;
        }
        .btn-submit:hover { box-shadow: 0 0 20px #ffcc00; transform: scale(1.03); }
        
        .links-container { margin-top: 20px; display: flex; flex-direction: column; gap: 10px; }
        .register-link { color: #00d4ff; text-decoration: none; font-size: 15px; transition: 0.3s; }
        .register-link:hover { color: white; text-shadow: 0 0 5px #00d4ff; }
        
        .forgot-link { color: #a1b0c9; text-decoration: none; font-size: 13px; font-style: italic; }
        .forgot-link:hover { color: #ffcc00; }

        .error-msg { 
            color: #ff4d4d; margin-bottom: 15px; font-weight: bold; 
            background: rgba(255,77,77,0.1); padding: 10px; border-radius: 8px; border: 1px solid #ff4d4d;
        }
        .success-msg { 
            color: #00ffcc; margin-bottom: 15px; font-weight: bold; 
            background: rgba(0,255,204,0.1); padding: 10px; border-radius: 8px; border: 1px solid #00ffcc;
        }
    </style>
</head>
<body>
    <div class="login-box">
        <div style="width: 65px; height: 65px; border: 3px solid #ffcc00; border-radius: 50%; margin: 0 auto 15px; display: flex; justify-content: center; align-items: center; font-size: 35px; color: #ffcc00; box-shadow: 0 0 15px #ffcc00; font-weight: bold;">?</div>
        <h2>Đăng Nhập</h2>

        @if (ViewBag.Error != null)
        {
            <div class="error-msg"><i class="fas fa-exclamation-circle"></i> @ViewBag.Error</div>
        }
        
        @if (ViewBag.Success != null)
        {
            <div class="success-msg"><i class="fas fa-check-circle"></i> @ViewBag.Success</div>
        }

        <form method="post" action="/Account/Login">
            <div class="input-group">
                <input type="text" name="Username" placeholder="Tên tài khoản" required autocomplete="off" />
            </div>
            <div class="input-group">
                <input type="password" name="Password" placeholder="Mật khẩu" required />
            </div>
            
            <div style="text-align: right; margin-bottom: 15px; padding-right: 10px;">
                <a href="/Account/ForgotPassword" class="forgot-link">Bạn quên mật khẩu?</a>
            </div>

            <button type="submit" class="btn-submit">VÀO TRƯỜNG QUAY</button>
        </form>

        <div class="links-container">
            <a href="/Account/Register" class="register-link">Chưa có vé? Đăng ký ngay</a>
        </div>
    </div>
</body>
</html>