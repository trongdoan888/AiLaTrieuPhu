@model AiLaTrieuPhu.Models.User
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập Quản trị - Ai Là Triệu Phú</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        body { 
            margin: 0; padding: 0; height: 100vh; display: flex; justify-content: center; align-items: center;
            background: radial-gradient(circle at center, #2b0505 0%, #0a0000 100%);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; color: white;
        }
        .login-box {
            background: rgba(0, 0, 0, 0.8); padding: 40px; border-radius: 20px;
            border: 2px solid #ff4d4d; box-shadow: 0 0 30px rgba(255, 77, 77, 0.5);
            text-align: center; width: 100%; max-width: 350px;
        }
        .login-box h2 { color: #ff4d4d; margin-top: 0; margin-bottom: 25px; font-size: 26px; text-transform: uppercase; }
        .input-group { margin-bottom: 20px; text-align: left; }
        .input-group input {
            width: 100%; padding: 12px; border-radius: 30px; border: 1px solid #ff4d4d;
            background: transparent; color: white; outline: none; font-size: 16px; box-sizing: border-box;
        }
        .input-group input::placeholder { color: #888; }
        .btn-submit {
            width: 100%; padding: 12px; border-radius: 30px; border: none;
            background: linear-gradient(180deg, #ff4d4d, #990000); color: white;
            font-size: 18px; font-weight: bold; cursor: pointer; transition: 0.3s;
        }
        .btn-submit:hover { box-shadow: 0 0 20px #ff4d4d; transform: scale(1.05); }
        .error-msg { color: #ffcc00; margin-bottom: 15px; font-weight: bold; }
        .back-link { display: block; margin-top: 20px; color: #888; text-decoration: none; font-size: 14px;}
        .back-link:hover { color: white; }
    </style>
</head>
<body>
    <div class="login-box">
        <h2><i class="fas fa-user-shield"></i> Quản Trị Viên</h2>
        @if (ViewBag.Error != null)
        {
            <div class="error-msg">@ViewBag.Error</div>
        }
        <form method="post" action="/Account/AdminLogin">
            <div class="input-group">
                <input type="text" name="Username" placeholder="Tên tài khoản Admin" required autocomplete="off" />
            </div>
            <div class="input-group">
                <input type="password" name="Password" placeholder="Mật khẩu" required />
            </div>
            <button type="submit" class="btn-submit">TRUY CẬP HỆ THỐNG</button>
        </form>
        
        <a href="/Account/Login" class="back-link"><i class="fas fa-arrow-left"></i> Về trang đăng nhập người chơi</a>
    </div>
</body>
</html>