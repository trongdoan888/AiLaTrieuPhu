@{ Layout = null; }
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Đấu Trường PvP - Ai Là Triệu Phú</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&display=swap');
        body { background: #030712; color: white; font-family: 'Rajdhani', sans-serif; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
        .lobby-card { background: rgba(6, 15, 30, 0.9); padding: 40px; border-radius: 20px; border: 2px solid #00d4ff; width: 500px; text-align: center; box-shadow: 0 0 30px rgba(0, 212, 255, 0.2); }
        
        .vs-container { display: flex; justify-content: space-around; align-items: center; margin: 30px 0; }
        .player-slot { width: 150px; padding: 20px; border: 1px solid rgba(255,255,255,0.1); border-radius: 15px; background: rgba(0,0,0,0.3); transition: 0.3s; }
        .player-slot.active { border-color: #00ffcc; box-shadow: 0 0 15px #00ffcc; }
        .p-name { font-size: 20px; font-weight: bold; margin-top: 10px; display: block; overflow: hidden; text-overflow: ellipsis; }
        .ready-badge { font-size: 12px; padding: 4px 8px; border-radius: 5px; background: #ff4d4d; color: white; margin-top: 5px; display: inline-block; }
        .ready-badge.is-ready { background: #00ffcc; color: black; }

        .btn-ready { 
            width: 100%; padding: 15px; background: #ffcc00; color: black; border: none; 
            border-radius: 10px; font-weight: 700; font-size: 20px; cursor: pointer; transition: 0.3s;
            text-transform: uppercase;
        }
        .btn-ready:hover { background: #ffd633; transform: scale(1.05); }
        .btn-ready:disabled { background: #555; cursor: not-allowed; }

        .input-room { width: 100%; padding: 12px; background: #020813; border: 1px solid #00d4ff; color: #ffcc00; border-radius: 10px; text-align: center; font-size: 20px; margin-bottom: 10px; }
        .btn-back { background: none; border: 1px solid #ff4d4d; color: #ff4d4d; padding: 8px 15px; border-radius: 5px; cursor: pointer; margin-top: 15px; }
    </style>
</head>
<body>
    <div class="lobby-card" id="mainLobby">
        <h2 id="lobbyTitle" style="color: #00d4ff;">ĐẤU TRƯỜNG 1VS1</h2>
        
        <div id="divJoin">
            <button class="btn-ready" style="background:#00d4ff; margin-bottom:20px;" onclick="joinRandom()">
                <i class="fas fa-random"></i> GHÉP NGẪU NHIÊN
            </button>
            
            <p style="color:#a1b0c9;">HOẶC NHẬP MÃ PHÒNG RIÊNG</p>
            <input type="text" id="roomIdInput" class="input-room" placeholder="MÃ PIN (6 SỐ)" />
            <div style="display: flex; gap: 10px;">
                <button class="btn-ready" style="flex:1" onclick="joinPrivate()">VÀO PHÒNG</button>
                <button class="btn-ready" style="flex:1; background:#ffcc00" onclick="createPrivate()">TẠO MỚI</button>
            </div>
            <a href="/Home/Index" style="display:block; margin-top:20px; color:#aaa; text-decoration:none;">Quay lại trang chủ</a>
        </div>

        <div id="divWaiting" style="display:none;">
            <div style="background:rgba(0,212,255,0.1); padding:10px; border-radius:10px; margin-bottom:20px;">
                MÃ PHÒNG: <b id="displayRoomId" style="color:#ffcc00; font-size:24px;">------</b>
            </div>

            <div class="vs-container">
                <div class="player-slot active" id="slotP1">
                    <i class="fas fa-user-astronaut fa-3x" style="color:#00d4ff"></i>
                    <span class="p-name" id="nameP1">...</span>
                    <span class="ready-badge" id="badgeP1">CHƯA SẴN SÀNG</span>
                </div>
                <div style="font-size: 30px; font-weight: 900; color: #ff4d4d;">VS</div>
                <div class="player-slot" id="slotP2">
                    <i class="fas fa-user-ninja fa-3x" id="iconP2" style="color:#777"></i>
                    <span class="p-name" id="nameP2">Trống...</span>
                    <span class="ready-badge" id="badgeP2">---</span>
                </div>
            </div>

            <button class="btn-ready" id="btnReadyAction" onclick="sendReady()" disabled>SẴN SÀNG!</button>
            <button class="btn-back" onclick="window.location.reload()"><i class="fas fa-times"></i> Hủy và thoát</button>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/gamehub")
            .withAutomaticReconnect()
            .build();

        let currentRoomId = "";
        const myName = "@Context.Session.GetString("Username")";

        connection.start().catch(err => console.error(err));

        function joinRandom() {
            connection.invoke("JoinRandom", myName);
        }

        function createPrivate() {
            connection.invoke("CreatePrivateRoom", myName);
        }

        function joinPrivate() {
            const id = document.getElementById('roomIdInput').value;
            if(id) connection.invoke("JoinPrivateRoom", id, myName);
            else Swal.fire("Lỗi", "Vui lòng nhập mã phòng", "error");
        }

        function sendReady() {
            if (!currentRoomId || currentRoomId === "") {
                // Phòng ngừa lỗi nếu ID vẫn chưa được đồng bộ
                currentRoomId = document.getElementById('displayRoomId').innerText;
            }
            
            const btn = document.getElementById('btnReadyAction');
            btn.disabled = true;
            btn.innerText = "ĐÃ SẴN SÀNG";
            btn.style.background = "#555";
            connection.invoke("SetReady", currentRoomId);
        }

        // --- LẮNG NGHE SỰ KIỆN ---
        connection.on("RoomCreated", (id) => {
            currentRoomId = id;
            document.getElementById('divJoin').style.display = 'none';
            document.getElementById('divWaiting').style.display = 'block';
            document.getElementById('displayRoomId').innerText = id;
            document.getElementById('nameP1').innerText = myName;
        });

        // ĐÃ SỬA: Thêm tham số thứ 3 roomIdFromServer
        connection.on("UpdateRoomStatus", (p1, p2, roomIdFromServer) => {
            document.getElementById('divJoin').style.display = 'none';
            document.getElementById('divWaiting').style.display = 'block';
            
            // Cập nhật ID phòng cho cả 2 máy
            if (roomIdFromServer) {
                currentRoomId = roomIdFromServer;
                document.getElementById('displayRoomId').innerText = roomIdFromServer;
            }

            document.getElementById('nameP1').innerText = p1;
            document.getElementById('nameP2').innerText = p2 || "Trống...";
            
            if(p2) {
                document.getElementById('slotP2').classList.add('active');
                document.getElementById('iconP2').style.color = "#ff4d4d";
                document.getElementById('badgeP2').innerText = "CHƯA SẴN SÀNG";
                document.getElementById('btnReadyAction').disabled = false;
            }
        });

        connection.on("PlayerReadyUpdate", (r1, r2) => {
            if(r1) { 
                document.getElementById('badgeP1').innerText = "ĐÃ SẴN SÀNG";
                document.getElementById('badgeP1').classList.add('is-ready');
            }
            if(r2) {
                document.getElementById('badgeP2').innerText = "ĐÃ SẴN SÀNG";
                document.getElementById('badgeP2').classList.add('is-ready');
            }
        });

        connection.on("StartGameCountdown", () => {
            let timer = 3;
            Swal.fire({
                title: 'TRẬN ĐẤU BẮT ĐẦU!',
                html: `Bắt đầu sau <b style="font-size:50px; color:#00ffcc">${timer}</b> giây`,
                timer: 3000,
                showConfirmButton: false,
                allowOutsideClick: false,
                background: 'rgba(6,15,30,0.95)',
                color: '#fff',
                didOpen: () => {
                    const b = Swal.getHtmlContainer().querySelector('b');
                    const interval = setInterval(() => {
                        timer--;
                        if(timer > 0) b.textContent = timer;
                        else clearInterval(interval);
                    }, 1000);
                }
            }).then(() => {
                window.location.href = "/Game/PvPPlaying?roomId=" + currentRoomId;
            });
        });

        connection.on("Error", (msg) => Swal.fire("Thông báo", msg, "info"));
    </script>
</body>
</html>