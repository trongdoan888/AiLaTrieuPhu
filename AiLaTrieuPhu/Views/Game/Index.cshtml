@model AiLaTrieuPhu.Models.Question
@{
    Layout = null;    
    // Lấy số Câu/Level hiện tại (từ 1 đến 15)    
    int currentLevel = ViewBag.CurrentLevel ?? 1;

    // Danh sách tiền thưởng tương ứng với 15 level
    int[] moneyLadder = { 200, 400, 600, 1000, 2000, 3000, 6000, 10000, 14000, 22000, 30000, 40000, 60000, 85000, 150000 };
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đang chơi - Ai Là Triệu Phú</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&display=swap');

        /* ================= NỀN LƯỚI KHÔNG GIAN ĐỒNG BỘ ================= */
        body, html {
            margin: 0; padding: 0; min-height: 100vh;
            font-family: 'Rajdhani', 'Segoe UI', sans-serif;
            background-color: #030712;
            background-image: 
                radial-gradient(circle at 50% 50%, rgba(0, 212, 255, 0.1) 0%, transparent 80%),
                linear-gradient(rgba(0, 212, 255, 0.05) 1px, transparent 1px),
                linear-gradient(90deg, rgba(0, 212, 255, 0.05) 1px, transparent 1px);
            background-size: 100% 100%, 30px 30px, 30px 30px;
            color: white; overflow: hidden; display: flex; flex-direction: column;
        }

        /* ================= TOP BAR KÍNH MỜ ================= */
        .top-bar {
            display: flex; justify-content: space-between; align-items: center;
            padding: 15px 40px; 
            background: rgba(6, 15, 30, 0.6); backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(0, 212, 255, 0.3);
            box-shadow: 0 10px 30px rgba(0,0,0,0.5); z-index: 10;
        }
        
        .btn-quit {
            color: #ff4d4d; text-decoration: none; font-size: 18px; font-weight: bold; text-transform: uppercase;
            border: 1px solid rgba(255, 77, 77, 0.5); padding: 10px 20px; border-radius: 8px; transition: 0.3s;
            background: rgba(255, 77, 77, 0.1); display: inline-flex; align-items: center; gap: 8px;
        }
        .btn-quit:hover { background: #ff4d4d; color: white; box-shadow: 0 0 15px #ff4d4d; }

        .btn-sound {
            background: rgba(0, 212, 255, 0.1); border: 1px solid rgba(0, 212, 255, 0.5); color: #00d4ff;
            border-radius: 8px; width: 45px; height: 45px; cursor: pointer;
            font-size: 18px; transition: 0.3s; margin-left: 15px;
        }
        .btn-sound:hover { background: #00d4ff; color: #000; box-shadow: 0 0 15px #00d4ff; }
        .btn-sound.muted { border-color: #ff4d4d; color: #ff4d4d; background: rgba(255,77,77,0.1); }

        .timer-box {
            width: 80px; height: 80px; background: radial-gradient(circle, #00d4ff, #005580);
            border: 3px solid #fff; border-radius: 50%; display: flex; justify-content: center; align-items: center;
            font-size: 35px; font-weight: bold; box-shadow: 0 0 20px #00d4ff;
        }

        .level-info-container { text-align: right; }
        .badge-level { font-size: 26px; font-weight: 700; color: #ffcc00; text-transform: uppercase; letter-spacing: 2px; text-shadow: 0 0 10px rgba(255,204,0,0.5); margin-bottom: 5px; }
        .badge-money { font-size: 18px; color: #a1b0c9; font-weight: 600; }
        .badge-money span { color: #00ffcc; text-shadow: 0 0 10px rgba(0,255,204,0.5); font-size: 20px;}

        /* ================= BỐ CỤC CHÍNH (MÁY TÍNH) ================= */
        .main-game-layout {
            display: flex; gap: 40px; max-width: 1400px; width: 100%; margin: 0 auto; 
            padding: 30px; flex: 1; align-items: flex-end; justify-content: center;
        }
        
        .game-content {
            flex: 1; max-width: 900px; display: flex; flex-direction: column; justify-content: flex-end;
        }

        /* --- QUYỀN TRỢ GIÚP --- */
        .lifelines { display: flex; justify-content: center; gap: 20px; margin-bottom: 30px; }
        .lifeline-btn {
            width: 70px; height: 50px; background: rgba(6, 15, 30, 0.8); backdrop-filter: blur(5px);
            border: 1px solid rgba(255, 204, 0, 0.5); border-radius: 12px; color: #ffcc00;
            font-size: 22px; cursor: pointer; transition: 0.3s; box-shadow: 0 0 15px rgba(0,0,0,0.5);
        }
        .lifeline-btn:hover:not(.used) { background: #ffcc00; color: #000; box-shadow: 0 0 20px rgba(255,204,0,0.6); transform: translateY(-5px); }
        .lifeline-btn.used { opacity: 0.2; pointer-events: none; border-color: red; color: red; }

        /* --- CÂU HỎI VÀ ĐÁP ÁN --- */
        .question-box {
            background: rgba(6, 15, 30, 0.7); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
            border: 2px solid rgba(0, 212, 255, 0.5); border-radius: 20px; padding: 30px 40px;
            text-align: center; font-size: 26px; font-weight: 600; margin-bottom: 30px;
            box-shadow: 0 15px 30px rgba(0,0,0,0.5), inset 0 0 20px rgba(0,212,255,0.1);
            animation: pulse-border 2s infinite alternate; letter-spacing: 1px;
        }
        
        .answers-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        .answer-btn {
            background: rgba(6, 15, 30, 0.7); backdrop-filter: blur(10px);
            border: 1px solid rgba(0, 212, 255, 0.3); border-radius: 15px; padding: 20px 30px;
            color: white; font-size: 22px; text-align: left; cursor: pointer; transition: all 0.3s ease;
            box-shadow: 0 10px 20px rgba(0,0,0,0.3); position: relative; overflow: hidden; font-family: inherit; font-weight: 600;
        }
        .answer-btn span.letter { color: #ffcc00; font-weight: 700; margin-right: 15px; font-size: 24px;}
        
        .answer-btn:hover {
            background: rgba(0, 212, 255, 0.1); border-color: #00d4ff;
            box-shadow: 0 0 25px rgba(0, 212, 255, 0.3); transform: scale(1.02);
        }

        /* --- CỘT PHẢI: THANG TIỀN THƯỞNG KÍNH MỜ --- */
        .money-ladder-container {
            width: 320px; background: rgba(6, 15, 30, 0.6); backdrop-filter: blur(12px);
            border: 1px solid rgba(0, 212, 255, 0.2); border-top: 1px solid rgba(0, 212, 255, 0.5);
            border-radius: 20px; padding: 25px; display: flex; flex-direction: column; justify-content: space-between;
            box-shadow: 0 20px 40px rgba(0,0,0,0.5); height: 100%; max-height: 750px;
        }

        .ladder-item {
            display: flex; justify-content: space-between; align-items: center;
            padding: 8px 15px; border-radius: 8px; font-weight: 600; font-size: 18px; transition: 0.3s;
        }
        
        .ladder-item.normal { color: #a1b0c9; }
        .ladder-item.milestone { 
            color: #fff; text-shadow: 0 0 5px rgba(255,255,255,0.5); 
            background: rgba(255, 255, 255, 0.05); border-left: 3px solid #fff;
        }
        .ladder-item.active { 
            background: #ffcc00; color: #000; font-weight: 700; font-size: 20px;
            box-shadow: 0 0 20px rgba(255,204,0,0.6); transform: scale(1.05); z-index: 2; border: none;
        }
        .ladder-item.passed { color: #00ffcc; opacity: 0.5; }
        
        .ladder-level { width: 45px; text-align: left; }
        .ladder-money { flex: 1; text-align: right; letter-spacing: 1px;}

        /* Cảnh báo nhấp nháy khi hết giờ (ghi đè CSS cũ) */
        .timer-warning { background: radial-gradient(circle, #ff4d4d, #990000) !important; box-shadow: 0 0 30px #ff4d4d !important; animation: pulse-danger 0.5s infinite !important;}

        @@keyframes pulse-border { from { box-shadow: 0 0 10px rgba(0,212,255,0.2); } to { box-shadow: 0 0 25px rgba(0,212,255,0.5), inset 0 0 10px rgba(0,212,255,0.1); } }
        @@keyframes pulse-danger { 0% { transform: scale(1); } 50% { transform: scale(1.1); } 100% { transform: scale(1); } }
    </style>
</head>
<body>

    <audio id="bgMusic" loop>
        <source src="/audio/bg-music.mp3" type="audio/mpeg">
    </audio>

    <div class="top-bar">
        <div style="display: flex; align-items: center;">
            <a href="#" class="btn-quit" id="btnQuitGame"><i class="fas fa-power-off"></i> Dừng chơi</a>
            <button id="btnToggleSound" class="btn-sound" title="Bật/Tắt Nhạc"><i class="fas fa-volume-up"></i></button>
        </div>
        
        <div class="timer-box" id="timer">60</div>
        
        <div class="level-info-container">
            <div class="badge-level">CÂU @currentLevel / 15</div>
            <div class="badge-money">
                <i class="fas fa-star" style="color: #ffcc00;"></i> Điểm: @(ViewBag.Score ?? 0) &nbsp;|&nbsp; 
                <i class="fas fa-sack-dollar" style="color: #00ffcc;"></i> Tiền: <span>@(String.Format("{0:N0}", ViewBag.Money ?? 0)) VNĐ</span>
            </div>
        </div>
    </div>

    <div class="main-game-layout">
        
        <div class="game-content">
            <div class="lifelines">
                <button class="lifeline-btn @(ViewBag.Used5050 ? "used" : "")" title="50/50" id="btn5050">
                    <i class="fas fa-star-half-alt"></i>
                </button>
                <button class="lifeline-btn @(ViewBag.UsedCall ? "used" : "")" title="Gọi điện thoại" id="btnCall">
                    <i class="fas fa-phone-alt"></i>
                </button>
                <button class="lifeline-btn @(ViewBag.UsedAudience ? "used" : "")" title="Hỏi ý kiến khán giả" id="btnAudience">
                    <i class="fas fa-users"></i>
                </button>
            </div>

            <div class="question-box">
                @(Model?.Content ?? "Đang tải câu hỏi...")
            </div>

            <form method="post" action="/Game/CheckAnswer" id="answerForm">
                <input type="hidden" name="questionId" value="@Model.Id" />
                <input type="hidden" name="timeUsed" id="timeUsed" value="0" />
                <input type="hidden" id="correctAnswer" value="@Model.CorrectAnswer" />

                <div class="answers-grid">
                    <button type="button" class="answer-btn" value="A">
                        <span class="letter">A:</span> @(Model?.A ?? "Đáp án A")
                    </button>
                    <button type="button" class="answer-btn" value="B">
                        <span class="letter">B:</span> @(Model?.B ?? "Đáp án B")
                    </button>
                    <button type="button" class="answer-btn" value="C">
                        <span class="letter">C:</span> @(Model?.C ?? "Đáp án C")
                    </button>
                    <button type="button" class="answer-btn" value="D">
                        <span class="letter">D:</span> @(Model?.D ?? "Đáp án D")
                    </button>
                </div>
            </form>
        </div>

        <div class="money-ladder-container">
            @for (int i = 15; i >= 1; i--)
            {
                bool isMilestone = (i == 5 || i == 10 || i == 15);
                string cssClass = "ladder-item ";

                if (i == currentLevel) { cssClass += "active"; } 
                else if (i < currentLevel) { cssClass += "passed"; } 
                else if (isMilestone) { cssClass += "milestone"; } 
                else { cssClass += "normal"; }

                <div class="@cssClass">
                    <span class="ladder-level">
                        @if (isMilestone && i >= currentLevel) { <i class="fas fa-gem" style="font-size: 10px; margin-right: 8px; color: #00d4ff;"></i> }
                        @i
                    </span>
                    <span class="ladder-money">
                        @String.Format("{0:N0}", moneyLadder[i - 1])
                    </span>
                </div>
            }
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/game.js" asp-append-version="true"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const bgMusic = document.getElementById("bgMusic");
            const btnToggleSound = document.getElementById("btnToggleSound");
            const iconSound = btnToggleSound.querySelector("i");
            
            let isMusicPlaying = false;

            function playMusic() {
                bgMusic.volume = 0.4; 
                bgMusic.play().then(() => {
                    isMusicPlaying = true;
                    iconSound.className = "fas fa-volume-up";
                    btnToggleSound.classList.remove("muted");
                }).catch(err => console.log("Trình duyệt chặn autoplay"));
            }

            document.body.addEventListener('click', function() {
                if (!isMusicPlaying && bgMusic.paused) {
                    playMusic();
                }
            }, { once: true });

            btnToggleSound.addEventListener("click", function(e) {
                e.stopPropagation(); 
                if (bgMusic.paused) {
                    playMusic();
                } else {
                    bgMusic.pause();
                    isMusicPlaying = false;
                    iconSound.className = "fas fa-volume-mute";
                    btnToggleSound.classList.add("muted");
                }
            });
        });
    </script>
</body>
</html>