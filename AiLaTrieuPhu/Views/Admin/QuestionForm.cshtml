@model AiLaTrieuPhu.Models.Question
@{ Layout = null; }
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@(Model.Id == 0 ? "Thêm" : "Sửa") Câu hỏi</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        body { background: #020813; color: white; font-family: 'Segoe UI', Tahoma, sans-serif; padding: 30px; margin: 0; display: flex; justify-content: center;}
        .form-container { background: linear-gradient(180deg, #0a1f44, #051024); padding: 40px; border-radius: 15px; width: 100%; max-width: 800px; border: 1px solid #00d4ff; box-shadow: 0 0 20px rgba(0,212,255,0.2);}
        .form-group { margin-bottom: 20px; }
        .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        label { display: block; color: #ffcc00; font-weight: bold; margin-bottom: 8px; }
        input, select, textarea { width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #1a4a8a; background: #020813; color: white; outline: none; box-sizing: border-box; font-size: 16px; transition: 0.3s;}
        input:focus, select:focus, textarea:focus { border-color: #00d4ff; box-shadow: 0 0 10px rgba(0,212,255,0.3); }
        .btn-submit { background: #00d4ff; color: black; padding: 15px; border: none; border-radius: 8px; font-weight: bold; font-size: 18px; cursor: pointer; width: 100%; transition: 0.3s; margin-top: 10px; text-transform: uppercase;}
        .btn-submit:hover { background: #ffcc00; box-shadow: 0 0 15px #ffcc00; }
        .btn-cancel { color: #ff4d4d; text-decoration: none; display: inline-block; margin-bottom: 20px; transition: 0.3s; font-size: 16px;}
        .btn-cancel:hover { text-shadow: 0 0 10px #ff4d4d; }
    </style>
</head>
<body>
    <div class="form-container">
        <a href="/Admin/Questions" class="btn-cancel"><i class="fas fa-arrow-left"></i> Hủy và quay lại</a>
        <h2 style="color: #fff; text-transform: uppercase; margin-top: 0; text-align: center;">
            <i class="fas fa-edit" style="color:#00d4ff;"></i> @(Model.Id == 0 ? "Thêm Câu Hỏi Mới" : "Cập Nhật Câu Hỏi")
        </h2>

        <form method="post" action="/Admin/SaveQuestion">
            <input type="hidden" name="Id" value="@Model.Id" />
            
            <div class="form-group">
                <label>Nội dung câu hỏi:</label>
                <textarea name="Content" rows="4" required placeholder="Nhập câu hỏi vào đây...">@Model.Content</textarea>
            </div>

            <div class="form-group">
                <label>Level (Độ khó từ 1 - 15):</label>
                <input type="number" name="Level" value="@(Model.Level == 0 ? 1 : Model.Level)" min="1" max="15" required />
            </div>

            <div class="grid-2">
                <div class="form-group"><label>Đáp án A:</label><input type="text" name="A" value="@Model.A" required /></div>
                <div class="form-group"><label>Đáp án B:</label><input type="text" name="B" value="@Model.B" required /></div>
                <div class="form-group"><label>Đáp án C:</label><input type="text" name="C" value="@Model.C" required /></div>
                <div class="form-group"><label>Đáp án D:</label><input type="text" name="D" value="@Model.D" required /></div>
            </div>

            <div class="form-group">
                <label>Đáp án đúng:</label>
                <select name="CorrectAnswer" required>
                    <option value="A" selected="@(Model.CorrectAnswer == "A")">Phương án A</option>
                    <option value="B" selected="@(Model.CorrectAnswer == "B")">Phương án B</option>
                    <option value="C" selected="@(Model.CorrectAnswer == "C")">Phương án C</option>
                    <option value="D" selected="@(Model.CorrectAnswer == "D")">Phương án D</option>
                </select>
            </div>

            <button type="submit" class="btn-submit"><i class="fas fa-save"></i> Lưu Dữ Liệu</button>
        </form>
    </div>
</body>
</html>