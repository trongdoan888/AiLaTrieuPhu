@model AiLaTrieuPhu.Models.Question
@{ Layout = null; }
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@(Model.Id == 0 ? "Thêm" : "Sửa") Câu hỏi - Admin</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&display=swap');
        body { background: #020813; color: white; font-family: 'Rajdhani', 'Segoe UI', sans-serif; padding: 30px; margin: 0; display: flex; justify-content: center;}
        .form-container { background: linear-gradient(180deg, #0a1f44, #051024); padding: 40px; border-radius: 15px; width: 100%; max-width: 800px; border: 1px solid #00d4ff; box-shadow: 0 0 20px rgba(0,212,255,0.2);}
        .form-group { margin-bottom: 20px; }
        .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        label { display: block; color: #00d4ff; font-weight: bold; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 1px; }
        input, select, textarea { width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #1a4a8a; background: #020813; color: white; outline: none; box-sizing: border-box; font-size: 16px; transition: 0.3s; font-family: inherit; }
        input:focus, select:focus, textarea:focus { border-color: #ffcc00; box-shadow: 0 0 10px rgba(255,204,0,0.3); }
        .btn-submit { background: #ffcc00; color: black; padding: 15px; border: none; border-radius: 8px; font-weight: bold; font-size: 18px; cursor: pointer; width: 100%; transition: 0.3s; margin-top: 10px; text-transform: uppercase; letter-spacing: 2px;}
        .btn-submit:hover { background: #fff; box-shadow: 0 0 20px #ffcc00; transform: scale(1.02); }
        .btn-cancel { color: #a1b0c9; text-decoration: none; display: inline-block; margin-bottom: 20px; transition: 0.3s; font-size: 16px;}
        .btn-cancel:hover { color: #fff; text-shadow: 0 0 10px #fff; }
        .highlight-label { color: #ffcc00 !important; }
    </style>
</head>
<body>
    <div class="form-container">
        <a href="/Admin/Questions" class="btn-cancel"><i class="fas fa-arrow-left"></i> Quay lại danh sách</a>
        
        <h2 style="color: #fff; text-transform: uppercase; margin-top: 0; text-align: center; letter-spacing: 3px;">
            <i class="fas fa-database" style="color:#ffcc00;"></i> @(Model.Id == 0 ? "Thêm Câu Hỏi Mới" : "Cập Nhật Câu Hỏi")
        </h2>

        <form method="post" action="/Admin/SaveQuestion">
            <input type="hidden" name="Id" value="@Model.Id" />
            
            <div class="grid-2">
                <div class="form-group">
                    <label class="highlight-label">Lĩnh vực kiến thức:</label>
                    <select name="Category" required>
                        <option value="Toán học" selected="@(Model.Category == "Toán học")">Toán học</option>
                        <option value="Văn học" selected="@(Model.Category == "Văn học")">Văn học</option>
                        <option value="Khoa học tự nhiên" selected="@(Model.Category == "Khoa học tự nhiên")">Khoa học tự nhiên</option>
                        <option value="Khoa học xã hội" selected="@(Model.Category == "Khoa học xã hội")">Khoa học xã hội</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="highlight-label">Cấp độ (Level 1 - 15):</label>
                    <input type="number" name="Level" value="@(Model.Level == 0 ? 1 : Model.Level)" min="1" max="15" required />
                </div>
            </div>

            <div class="form-group">
                <label>Nội dung câu hỏi:</label>
                <textarea name="Content" rows="3" required placeholder="Nhập nội dung câu hỏi...">@Model.Content</textarea>
            </div>

            <div class="form-group">
                <label><i class="fas fa-lightbulb"></i> Gợi ý (Hint):</label>
                <input type="text" name="Hint" value="@Model.Hint" placeholder="Nhập gợi ý ngắn gọn cho người chơi..." />
            </div>

            <div class="grid-2">
                <div class="form-group"><label>Đáp án A:</label><input type="text" name="A" value="@Model.A" required /></div>
                <div class="form-group"><label>Đáp án B:</label><input type="text" name="B" value="@Model.B" required /></div>
                <div class="form-group"><label>Đáp án C:</label><input type="text" name="C" value="@Model.C" required /></div>
                <div class="form-group"><label>Đáp án D:</label><input type="text" name="D" value="@Model.D" required /></div>
            </div>

            <div class="form-group">
                <label class="highlight-label">Đáp án đúng chính xác:</label>
                <select name="CorrectAnswer" required>
                    <option value="A" selected="@(Model.CorrectAnswer == "A")">Phương án A</option>
                    <option value="B" selected="@(Model.CorrectAnswer == "B")">Phương án B</option>
                    <option value="C" selected="@(Model.CorrectAnswer == "C")">Phương án C</option>
                    <option value="D" selected="@(Model.CorrectAnswer == "D")">Phương án D</option>
                </select>
            </div>

            <button type="submit" class="btn-submit"><i class="fas fa-save"></i> XÁC NHẬN LƯU DỮ LIỆU</button>
        </form>
    </div>
</body>
</html>