@{ Layout = null; }
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Admin Dashboard - Ai Là Triệu Phú</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        body { background: radial-gradient(circle at top, #020813 0%, #000000 100%); color: white; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; padding: 30px; margin: 0; min-height: 100vh;}
        .container { max-width: 1000px; margin: 0 auto; }
        .dashboard-cards { display: flex; gap: 20px; margin-bottom: 40px; flex-wrap: wrap; }
        .card { background: linear-gradient(180deg, #0a1f44, #051024); border: 1px solid #00d4ff; padding: 30px; border-radius: 15px; flex: 1; text-align: center; box-shadow: 0 0 15px rgba(0, 212, 255, 0.2); transition: 0.3s; min-width: 250px;}
        .card:hover { transform: translateY(-5px); box-shadow: 0 5px 20px rgba(0, 212, 255, 0.5); border-color: #ffcc00;}
        .card h3 { margin-top: 0; color: #00d4ff; text-transform: uppercase; font-size: 18px; }
        .card:hover h3 { color: #ffcc00; }
        .card h2 { color: #ffcc00; margin: 15px 0 0 0; font-size: 48px; text-shadow: 0 0 10px rgba(255, 204, 0, 0.5); }
        .menu-btn { display: inline-flex; align-items: center; justify-content: center; gap: 10px; padding: 15px 30px; background: #00d4ff; color: #000; text-decoration: none; font-weight: bold; border-radius: 30px; margin-right: 15px; transition: 0.3s; font-size: 16px; border: 2px solid #00d4ff;}
        .menu-btn:hover { background: #ffcc00; border-color: #ffcc00; box-shadow: 0 0 15px #ffcc00; }
        .btn-back { color: #ff4d4d; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; margin-bottom: 20px; border: 1px solid #ff4d4d; padding: 8px 15px; border-radius: 20px; transition: 0.3s;}
        .btn-back:hover { background: #ff4d4d; color: white; box-shadow: 0 0 10px #ff4d4d; }
    </style>
</head>
<body>
    <div class="container">
        <a href="/Home/Index" class="btn-back"><i class="fas fa-sign-out-alt"></i> Thoát trang Quản trị</a>
        <h1 style="color: #ffcc00; margin-bottom: 30px; text-transform: uppercase;"><i class="fas fa-cogs"></i> Hệ Thống Quản Trị Triệu Phú</h1>
        
        <div class="dashboard-cards">
            <div class="card">
                <h3><i class="fas fa-users"></i> Tổng Người Chơi</h3>
                <h2>@ViewBag.TotalUsers</h2>
            </div>
            <div class="card">
                <h3><i class="fas fa-database"></i> Tổng Câu Hỏi</h3>
                <h2>@ViewBag.TotalQuestions</h2>
            </div>
            <div class="card">
                <h3><i class="fas fa-gamepad"></i> Tổng Lượt Chơi</h3>
                <h2>@ViewBag.TotalGames</h2>
            </div>
        </div>

        <div style="text-align: center; margin-top: 50px;">
            <a href="/Admin/Questions" class="menu-btn"><i class="fas fa-question-circle"></i> Quản lý Câu hỏi</a>
            <a href="/Admin/Users" class="menu-btn"><i class="fas fa-user-cog"></i> Quản lý Tài khoản</a>
        </div>
    </div>
</body>
</html>