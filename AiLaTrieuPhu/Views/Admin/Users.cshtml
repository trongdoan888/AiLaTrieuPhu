@model IEnumerable<AiLaTrieuPhu.Models.User>
@{ Layout = null; }
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Quản lý Người chơi</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        body { background: #020813; color: white; font-family: 'Segoe UI', Tahoma, sans-serif; padding: 30px; margin: 0;}
        table { width: 100%; border-collapse: collapse; margin-top: 20px; background: rgba(10, 31, 68, 0.8); border-radius: 10px; overflow: hidden;}
        th, td { border: 1px solid rgba(0, 212, 255, 0.3); padding: 15px; text-align: left; }
        th { background: rgba(0,212,255,0.2); color: #ffcc00; text-transform: uppercase; }
        tr:hover { background: rgba(0, 212, 255, 0.1); }
        .btn { padding: 8px 12px; text-decoration: none; border-radius: 5px; font-weight: bold; font-size: 14px; transition: 0.3s; display: inline-flex; align-items: center; gap: 5px;}
        .btn-delete { background: #ff4d4d; color: white; border: 1px solid #ff4d4d;}
        .btn-delete:hover { background: transparent; color: #ff4d4d; box-shadow: 0 0 10px #ff4d4d;}
        .btn-disabled { background: transparent; color: #888; border: 1px solid #555; cursor: not-allowed; pointer-events: none;}
        .role-admin { color: #ffcc00; font-weight: bold; background: rgba(255, 204, 0, 0.2); padding: 5px 10px; border-radius: 20px;}
        .role-user { color: #00ffcc; }
        .btn-back { color: #00d4ff; text-decoration: none; font-size: 16px; display: inline-block; margin-bottom: 20px; transition: 0.3s;}
        .btn-back:hover { text-shadow: 0 0 10px #00d4ff; }
    </style>
</head>
<body>
    <a href="/Admin/Index" class="btn-back"><i class="fas fa-arrow-left"></i> Trở về Dashboard</a>
    
    <h2 style="color: #ffcc00; margin-top: 0;"><i class="fas fa-users"></i> Danh sách Tài khoản</h2>

    <table>
        <thead>
            <tr>
                <th width="80">ID</th>
                <th>Tên tài khoản</th>
                <th>Vai trò</th>
                <th>Ngày đăng ký</th>
                <th width="150">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var u in Model)
            {
                <tr>
                    <td>@u.Id</td>
                    <td style="font-weight: bold; font-size: 18px;">@u.Username</td>
                    <td>
                        @if(u.Role == "Admin") 
                        { 
                            <span class="role-admin"><i class="fas fa-crown"></i> Admin</span> 
                        }
                        else 
                        { 
                            <span class="role-user"><i class="fas fa-user"></i> Người chơi</span> 
                        }
                    </td>
                    <td>@u.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        @if (u.Id == Context.Session.GetInt32("UserId"))
                        {
                            <span class="btn btn-disabled"><i class="fas fa-lock"></i> Đang Online</span>
                        }
                        else
                        {
                            <a href="/Admin/DeleteUser/@u.Id" class="btn btn-delete" 
                               onclick="return confirm('CẢNH BÁO: Bạn có chắc muốn xóa tài khoản @u.Username không? Dữ liệu chơi của họ cũng sẽ mất!');">
                               <i class="fas fa-trash-alt"></i> Xóa tài khoản
                            </a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</body>
</html>