@model IEnumerable<AiLaTrieuPhu.Models.Question>
@{ Layout = null; }
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Quản lý Câu hỏi - Admin</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&display=swap');
        body { background: #020813; color: white; font-family: 'Rajdhani', 'Segoe UI', sans-serif; padding: 30px; margin: 0; }
        
        /* Table Style */
        table { width: 100%; border-collapse: collapse; margin-top: 20px; background: rgba(10, 31, 68, 0.8); border-radius: 10px; overflow: hidden; box-shadow: 0 0 20px rgba(0,0,0,0.5); }
        th, td { border: 1px solid rgba(0, 212, 255, 0.2); padding: 12px; text-align: left; }
        th { background: rgba(0,212,255,0.2); color: #00d4ff; text-transform: uppercase; letter-spacing: 1px; }
        tr:hover { background: rgba(0, 212, 255, 0.1); }

        /* Button Style */
        .btn { padding: 8px 15px; text-decoration: none; border-radius: 5px; color: black; font-weight: bold; border: none; cursor: pointer; transition: 0.3s; display: inline-flex; align-items: center; gap: 5px; font-family: inherit; }
        .btn-add { background: #00d4ff; }
        .btn-add:hover { background: #fff; box-shadow: 0 0 15px #00d4ff; }
        .btn-edit { background: #ffcc00; }
        .btn-edit:hover { background: #fff; box-shadow: 0 0 15px #ffcc00;}
        .btn-delete { background: #ff4d4d; color: white;}
        .btn-delete:hover { background: #fff; color: #ff4d4d; box-shadow: 0 0 15px #ff4d4d;}
        
        /* Category Badges */
        .badge-cat { padding: 4px 8px; border-radius: 4px; font-size: 12px; font-weight: bold; text-transform: uppercase; border: 1px solid; }
        .cat-toan { border-color: #00d4ff; color: #00d4ff; background: rgba(0,212,255,0.1); }
        .cat-van { border-color: #ff66cc; color: #ff66cc; background: rgba(255,102,204,0.1); }
        .cat-khtn { border-color: #00ffcc; color: #00ffcc; background: rgba(0,255,204,0.1); }
        .cat-khxh { border-color: #ffcc00; color: #ffcc00; background: rgba(255,204,0,0.1); }

        .action-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; flex-wrap: wrap; background: rgba(6, 15, 30, 0.8); padding: 20px; border-radius: 10px; border: 1px solid #00d4ff; backdrop-filter: blur(10px); }
        .upload-form { display: flex; align-items: center; gap: 10px; }
        .upload-form input[type="file"] { color: #a1b0c9; background: #051024; border: 1px dashed #00d4ff; padding: 5px; border-radius: 5px;}
        
        .btn-back { color: #00d4ff; text-decoration: none; font-size: 16px; display: inline-block; margin-bottom: 20px; transition: 0.3s; font-weight: bold; }
        .btn-back:hover { text-shadow: 0 0 10px #00d4ff; transform: translateX(-5px); }

        .hint-text { color: #a1b0c9; font-style: italic; font-size: 13px; display: block; margin-top: 5px; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 5px; }
    </style>
</head>
<body>
    <a href="/Admin/Index" class="btn-back"><i class="fas fa-arrow-left"></i> TRỞ VỀ DASHBOARD</a>
    <h2 style="color: #ffcc00; margin-top: 0; text-transform: uppercase; letter-spacing: 2px;">
        <i class="fas fa-database"></i> Ngân hàng 120 câu hỏi
    </h2>

    @if (TempData["Success"] != null)
    {
        <div style="background: rgba(0, 255, 204, 0.1); color: #00ffcc; padding: 15px; margin-bottom: 20px; border-radius: 8px; font-weight: bold; border: 1px solid #00ffcc;">
            <i class="fas fa-check-circle"></i> @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div style="background: rgba(255, 77, 77, 0.1); color: #ff4d4d; padding: 15px; margin-bottom: 20px; border-radius: 8px; font-weight: bold; border: 1px solid #ff4d4d;">
            <i class="fas fa-exclamation-triangle"></i> @TempData["Error"]
        </div>
    }

    <div class="action-bar">
        <a href="/Admin/CreateQuestion" class="btn btn-add"><i class="fas fa-plus"></i> THÊM CÂU HỎI MỚI</a>
        
        <form method="post" action="/Admin/ImportExcel" enctype="multipart/form-data" class="upload-form">
            <div style="display:flex; flex-direction:column; gap:5px;">
                <span style="color: #ffcc00; font-weight: bold; font-size: 14px;">
                    <i class="fas fa-file-excel"></i> NHẬP EXCEL (9 CỘT: Loại, Level, Nội dung, A-D, Đáp án, Gợi ý)
                </span>
                <div style="display:flex; gap:10px;">
                    <input type="file" name="file" accept=".xlsx" required />
                    <button type="submit" class="btn btn-edit"><i class="fas fa-upload"></i> TẢI LÊN</button>
                </div>
            </div>
        </form>
    </div>

    <table>
        <thead>
            <tr>
                <th width="50">ID</th>
                <th width="150">Lĩnh vực</th>
                <th width="80">Level</th>
                <th>Nội dung câu hỏi & Gợi ý</th>
                <th width="80" style="text-align:center;">Đáp án</th>
                <th width="110">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var q in Model)
            {
                string catClass = q.Category switch {
                    "Toán học" => "cat-toan",
                    "Văn học" => "cat-van",
                    "Khoa học tự nhiên" => "cat-khtn",
                    "Khoa học xã hội" => "cat-khxh",
                    _ => ""
                };

                <tr>
                    <td style="opacity: 0.5;">#@q.Id</td>
                    <td><span class="badge-cat @catClass">@q.Category</span></td>
                    <td style="color: #ffcc00; font-weight: 700; text-align: center;">Lvl @q.Level</td>
                    <td>
                        <strong style="color: #fff;">@q.Content</strong>
                        @if(!string.IsNullOrEmpty(q.Hint))
                        {
                            <span class="hint-text"><i class="fas fa-lightbulb" style="color:#ffcc00;"></i> @q.Hint</span>
                        }
                    </td>
                    <td style="color:#00ffcc; font-weight:bold; text-align: center; font-size: 20px;">@q.CorrectAnswer</td>
                    <td>
                        <a href="/Admin/EditQuestion/@q.Id" class="btn btn-edit" title="Sửa"><i class="fas fa-edit"></i></a>
                        <a href="/Admin/DeleteQuestion/@q.Id" class="btn btn-delete" title="Xóa" onclick="return confirm('Xóa câu hỏi này?');"><i class="fas fa-trash-alt"></i></a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</body>
</html>