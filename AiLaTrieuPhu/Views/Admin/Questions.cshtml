@model IEnumerable<AiLaTrieuPhu.Models.Question>
@{ Layout = null; }
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Quản lý Câu hỏi - Admin</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&display=swap');
        body { background: #020813; color: white; font-family: 'Rajdhani', 'Segoe UI', sans-serif; padding: 30px; margin: 0; }
        
        /* Filter Bar & Action Bar */
        .cyber-bar { background: rgba(6, 15, 30, 0.8); padding: 20px; border-radius: 10px; border: 1px solid #00d4ff; backdrop-filter: blur(10px); margin-bottom: 20px; }
        .filter-form { display: flex; gap: 15px; flex-wrap: wrap; align-items: flex-end; margin-bottom: 20px; border-bottom: 1px dashed rgba(0, 212, 255, 0.3); padding-bottom: 20px; }
        .filter-group { display: flex; flex-direction: column; gap: 5px; }
        .filter-group label { font-size: 12px; color: #ffcc00; text-transform: uppercase; font-weight: bold; letter-spacing: 1px; }
        .filter-input { background: #051024; border: 1px solid #00d4ff; border-radius: 5px; padding: 10px; color: white; outline: none; transition: 0.3s; }
        .filter-input:focus { box-shadow: 0 0 10px rgba(0, 212, 255, 0.5); }

        /* Table Style */
        table { width: 100%; border-collapse: collapse; background: rgba(10, 31, 68, 0.8); border-radius: 10px; overflow: hidden; box-shadow: 0 0 20px rgba(0,0,0,0.5); }
        th, td { border: 1px solid rgba(0, 212, 255, 0.2); padding: 12px; text-align: left; }
        th { background: rgba(0,212,255,0.2); color: #00d4ff; text-transform: uppercase; }
        tr:hover { background: rgba(0, 212, 255, 0.1); }

        /* Button Style */
        .btn { padding: 10px 18px; text-decoration: none; border-radius: 5px; color: black; font-weight: bold; border: none; cursor: pointer; transition: 0.3s; display: inline-flex; align-items: center; gap: 8px; font-family: inherit; }
        .btn-filter { background: #ffcc00; }
        .btn-filter:hover { background: #fff; box-shadow: 0 0 15px #ffcc00; }
        .btn-add { background: #00d4ff; }
        .btn-add:hover { background: #fff; box-shadow: 0 0 15px #00d4ff; }
        .btn-delete { background: #ff4d4d; color: white; width: 40px; justify-content: center; }
        .btn-edit { background: #ffcc00; width: 40px; justify-content: center; }
        
        /* Category Badges */
        .badge-cat { padding: 4px 10px; border-radius: 4px; font-size: 11px; font-weight: bold; text-transform: uppercase; border: 1px solid; }
        .cat-toan { border-color: #00d4ff; color: #00d4ff; background: rgba(0,212,255,0.1); }
        .cat-van { border-color: #ff66cc; color: #ff66cc; background: rgba(255,102,204,0.1); }
        .cat-khtn { border-color: #00ffcc; color: #00ffcc; background: rgba(0,255,204,0.1); }
        .cat-khxh { border-color: #ffcc00; color: #ffcc00; background: rgba(255,204,0,0.1); }

        .btn-back { color: #00d4ff; text-decoration: none; font-size: 16px; display: inline-block; margin-bottom: 20px; font-weight: bold; }
        .hint-text { color: #a1b0c9; font-style: italic; font-size: 13px; display: block; margin-top: 5px; }
        .empty-msg { text-align: center; padding: 40px; color: #ff4d4d; font-weight: bold; letter-spacing: 1px; }
    </style>
</head>
<body>
    <a href="/Admin/Index" class="btn-back"><i class="fas fa-arrow-left"></i> TRỞ VỀ DASHBOARD</a>
    <h2 style="color: #ffcc00; margin-top: 0; text-transform: uppercase; letter-spacing: 2px;">
        <i class="fas fa-database"></i> Quản lý Ngân hàng Câu hỏi
    </h2>

    <div class="cyber-bar">
        <form method="get" action="/Admin/Questions" class="filter-form">
            <div class="filter-group" style="flex: 2;">
                <label><i class="fas fa-search"></i> Nội dung tìm kiếm</label>
                <input type="text" name="searchContent" class="filter-input" placeholder="Nhập ký tự liên quan đến câu hỏi..." value="@ViewBag.SearchContent">
            </div>
            
            <div class="filter-group" style="flex: 1;">
                <label><i class="fas fa-layer-group"></i> Lĩnh vực</label>
                <select name="category" class="filter-input">
                    <option value="">-- Tất cả --</option>
                    @foreach (var cat in (List<string>)ViewBag.Categories)
                    {
                        <option value="@cat" selected="@(ViewBag.CurrentCategory == cat)">@cat</option>
                    }
                </select>
            </div>

            <div class="filter-group">
                <label><i class="fas fa-signal"></i> Cấp độ</label>
                <select name="level" class="filter-input">
                    <option value="">Tất cả</option>
                    @for (int i = 1; i <= 15; i++)
                    {
                        <option value="@i" selected="@(ViewBag.CurrentLevel != null && (int)ViewBag.CurrentLevel == i)">Lvl @i</option>
                    }
                </select>
            </div>

            <div class="filter-group">
                <button type="submit" class="btn btn-filter"><i class="fas fa-filter"></i> LỌC DỮ LIỆU</button>
            </div>
            <div class="filter-group">
                <a href="/Admin/Questions" class="filter-input" style="text-decoration:none; text-align:center; background:#333;">XÓA LỌC</a>
            </div>
        </form>

        <div style="display:flex; justify-content: space-between; align-items: center; flex-wrap:wrap; gap:20px;">
            <a href="/Admin/CreateQuestion" class="btn btn-add"><i class="fas fa-plus"></i> THÊM CÂU HỎI THỦ CÔNG</a>
            
            <form method="post" action="/Admin/ImportExcel" enctype="multipart/form-data" style="display:flex; align-items:center; gap:10px;">
                <span style="color: #ffcc00; font-weight: bold; font-size: 13px;">NHẬP EXCEL:</span>
                <input type="file" name="file" accept=".xlsx" required style="font-size:12px; color:#00d4ff;" />
                <button type="submit" class="btn btn-filter" style="padding: 5px 15px;"><i class="fas fa-upload"></i> TẢI LÊN</button>
            </form>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div style="background: rgba(0, 255, 204, 0.1); color: #00ffcc; padding: 15px; margin-bottom: 20px; border-radius: 8px; border: 1px solid #00ffcc;">
            <i class="fas fa-check-circle"></i> @TempData["Success"]
        </div>
    }

    <table>
        <thead>
            <tr>
                <th width="50">ID</th>
                <th width="140">Lĩnh vực</th>
                <th width="80">Level</th>
                <th>Nội dung câu hỏi & Gợi ý</th>
                <th width="80" style="text-align:center;">Đáp án</th>
                <th width="110">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="6" class="empty-msg">KHÔNG TÌM THẤY CÂU HỎI NÀO PHÙ HỢP VỚI BỘ LỌC!</td>
                </tr>
            }
            @foreach (var q in Model)
            {
                string catClass = q.Category switch {
                    "Toán học" => "cat-toan",
                    "Văn học" => "cat-van",
                    "Khoa học tự nhiên" => "cat-khtn",
                    "Khoa học xã hội" => "cat-khxh",
                    _ => ""
                };

                <tr>
                    <td style="opacity: 0.5;">#@q.Id</td>
                    <td><span class="badge-cat @catClass">@q.Category</span></td>
                    <td style="color: #ffcc00; font-weight: 700; text-align: center;">Lvl @q.Level</td>
                    <td>
                        <strong style="color: #fff;">@q.Content</strong>
                        @if(!string.IsNullOrEmpty(q.Hint))
                        {
                            <span class="hint-text"><i class="fas fa-lightbulb" style="color:#ffcc00;"></i> @q.Hint</span>
                        }
                    </td>
                    <td style="color:#00ffcc; font-weight:bold; text-align: center; font-size: 18px;">@q.CorrectAnswer</td>
                    <td style="display:flex; gap:5px;">
                        <a href="/Admin/EditQuestion/@q.Id" class="btn btn-edit" title="Sửa"><i class="fas fa-edit"></i></a>
                        <a href="/Admin/DeleteQuestion/@q.Id" class="btn btn-delete" title="Xóa" onclick="return confirm('Xóa câu hỏi này?');"><i class="fas fa-trash-alt"></i></a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</body>
</html>