@model List<AiLaTrieuPhu.Models.Ranking>

<h2>Bảng xếp hạng</h2>

<table class="table">
    <tr>
        <th>Top</th>
        <th>User</th>
        <th>Điểm</th>
        <th>Thời gian</th>
    </tr>

    @for (int i = 0; i < Model.Count; i++)
    {
        <tr>
            <td>@(i + 1)</td>
            <td>@Model[i].User?.Username</td>
            <td>@Model[i].Score</td>
            <td>@Model[i].TimePlayed</td>
        </tr>
    }
</table>